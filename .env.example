# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram ID администраторов (через запятую)
# Узнать свой ID: напишите боту @userinfobot
ADMIN_TELEGRAM_IDS=123456789,987654321

# Публичный HTTPS-адрес Mini App (обязательно для Telegram)
# Пример после деплоя на Railway:
# WEBAPP_URL=https://your-app-name.up.railway.app/miniapp/
WEBAPP_URL=https://your-app-name.up.railway.app/miniapp/

# Путь к базе данных (на Railway — постоянный том)
# DATABASE_PATH=/data/crm.db

# Запускать бота вместе с API (true — один сервис на Railway)
RUN_BOT=true
